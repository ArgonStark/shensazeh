[Unit]
Description=Sazandeh gunicorn daemon
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/var/www/sazandeh
EnvironmentFile=/var/www/sazandeh/.env
ExecStart=/var/www/sazandeh/venv/bin/gunicorn \
    --workers 3 \
    --timeout 60 \
    --bind unix:/run/sazandeh.sock \
    --access-logfile /var/log/sazandeh/access.log \
    --error-logfile /var/log/sazandeh/error.log \
    config.wsgi:application
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target

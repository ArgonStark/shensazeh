# Copy this to /var/www/shensazeh/.env on the server and fill the values.
# (Do NOT commit the real .env to git.)

# --- Required for go-live ---
# Generate one with:  python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=CHANGE_ME_generate_a_50_char_random_key
DEBUG=False
ALLOWED_HOSTS=shensazeh.ir,www.shensazeh.ir
SITE_URL=https://shensazeh.ir

# Set to True ONLY after you install an HTTPS certificate (certbot). Leave unset for an HTTP demo.
# SECURE_SSL=True

# --- Database: SQLite (default) needs nothing else. ---
# To use MySQL instead, uncomment and fill:
# DB_ENGINE=django.db.backends.mysql
# DB_NAME=shensazeh
# DB_USER=shensazeh
# DB_PASSWORD=change-me
# DB_HOST=127.0.0.1
# DB_PORT=3306

# --- Optional integrations (NOT needed for the landing page) ---
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHANNEL_ID=
# SMS_API_KEY=
# SMS_SENDER=
# ANTHROPIC_API_KEY=
